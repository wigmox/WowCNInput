<Ui xmlns="http://www.blizzard.com/wow/ui/"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\FrameXML\UI.xsd">
	
	<Script file="Pinyin_Dict.lua" />
	<Script file="WowCNInput.lua" />

	<Frame name="WowCNInput" parent="UIParent" hidden="true" frameStrata="TOOLTIP" toplevel="true">
		<Size><AbsDimension x="500" y="60" /></Size>
		<Anchors><Anchor point="CENTER" /></Anchors>
		<Backdrop bgFile="Interface\Tooltips\UI-Tooltip-Background" edgeFile="Interface\Tooltips\UI-Tooltip-Border" tile="true">
			<EdgeSize><AbsValue val="24" /></EdgeSize>
			<TileSize><AbsValue val="24" /></TileSize>
			<BackgroundInsets><AbsInset left="4" right="4" top="4" bottom="4" /></BackgroundInsets>
		</Backdrop>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="LettersArea" inherits="GameFontNormal" hidden="false" justifyV="MIDDLE" justifyH="LEFT">
					<Size><AbsDimension x="460" y="25" /></Size>
					<Anchors>
						<Anchor point="TOPLEFT"><Offset><AbsDimension x="8" y="-8" /></Offset></Anchor>
					</Anchors>
				</FontString>
				<FontString name="CanArea" inherits="GameFontNormal" hidden="false" justifyV="MIDDLE" justifyH="LEFT">
					<Size><AbsDimension x="460" y="26" /></Size>
					<Anchors>
						<Anchor point="TOPLEFT"><Offset><AbsDimension x="8" y="-28" /></Offset></Anchor>
					</Anchors>
				</FontString>
				<FontString name="InfoArea" inherits="GameFontNormalSmall" hidden="false" justifyV="MIDDLE" justifyH="RIGHT">
					<Size><AbsDimension x="40" y="26" /></Size>
					<Anchors>
						<Anchor point="TOPRIGHT"><Offset><AbsDimension x="-8" y="-8" /></Offset></Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad>
				this:SetBackdropColor(0.05, 0.05, 0.05, 0.9);
				WowCNInput_OnLoad();
			</OnLoad>
			<OnEvent>WowCNInput_OnEvent(event);</OnEvent>
		</Scripts>
	</Frame>
</Ui>